{
    "version": 5,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "ninja-debug",
            "displayName": "Ninja Debug",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "binaryDir": "${sourceDir}/build/ninja-debug",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/msvc-md.cmake",
                "PROCROGUE_BUILD_GAME": "OFF",
                "PROCROGUE_BUILD_HEADLESS": "ON",
                "PROCROGUE_BUILD_TESTS": "OFF",
                "PROCROGUE_FETCH_SDL2": "OFF",
                "CMAKE_SUPPRESS_REGENERATION": "ON"
            }
        },
        {
            "name": "ninja-release",
            "displayName": "Ninja Release",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "binaryDir": "${sourceDir}/build/ninja-release",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/msvc-md.cmake",
                "PROCROGUE_BUILD_GAME": "OFF",
                "PROCROGUE_BUILD_HEADLESS": "ON",
                "PROCROGUE_BUILD_TESTS": "OFF",
                "PROCROGUE_FETCH_SDL2": "OFF",
                "CMAKE_SUPPRESS_REGENERATION": "ON"
            }
        },
        {
            "name": "ninja-debug-game",
            "displayName": "Ninja Debug (Game + SDL)",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "binaryDir": "${sourceDir}/build/ninja-debug-game",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/msvc-md.cmake",
                "PROCROGUE_BUILD_GAME": "ON",
                "PROCROGUE_BUILD_HEADLESS": "OFF",
                "PROCROGUE_BUILD_TESTS": "OFF",
                "PROCROGUE_FETCH_SDL2": "ON",
                "CMAKE_SUPPRESS_REGENERATION": "ON"
            }
        },
        {
            "name": "ninja-release-game",
            "displayName": "Ninja Release (Game + SDL)",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "binaryDir": "${sourceDir}/build/ninja-release-game",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/msvc-md.cmake",
                "PROCROGUE_BUILD_GAME": "ON",
                "PROCROGUE_BUILD_HEADLESS": "OFF",
                "PROCROGUE_BUILD_TESTS": "OFF",
                "PROCROGUE_FETCH_SDL2": "ON",
                "CMAKE_SUPPRESS_REGENERATION": "ON"
            }
        },
        {
            "name": "msvc-base",
            "hidden": true,
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "cacheVariables": {
                "PROCROGUE_FETCH_SDL2": "ON",
                "PROCROGUE_BUILD_GAME": "ON",
                "PROCROGUE_BUILD_TESTS": "OFF",
                "PROCROGUE_BUILD_HEADLESS": "ON"
            }
        },
        {
            "name": "msvc-vcpkg-base",
            "hidden": true,
            "inherits": "msvc-base",
            "environment": {
                "VCPKG_FORCE_SYSTEM_BINARIES": "1",
                "GIT": "C:/Program Files/Git/cmd/git.exe",
                "PATH": "C:/Program Files/Git/cmd;$penv{PATH}",
                "HTTP_PROXY": null,
                "HTTPS_PROXY": null,
                "ALL_PROXY": null,
                "http_proxy": null,
                "https_proxy": null,
                "all_proxy": null,
                "NO_PROXY": "localhost,127.0.0.1,::1",
                "no_proxy": "localhost,127.0.0.1,::1",
                "GIT_CONFIG_COUNT": "2",
                "GIT_CONFIG_KEY_0": "http.proxy",
                "GIT_CONFIG_VALUE_0": "",
                "GIT_CONFIG_KEY_1": "https.proxy",
                "GIT_CONFIG_VALUE_1": "",
                "GIT_TERMINAL_PROMPT": "0",
                "GCM_INTERACTIVE": "Never",
                "VCPKG_DOWNLOADS": "${sourceDir}/build/.vcpkg-downloads",
                "VCPKG_DEFAULT_BINARY_CACHE": "${sourceDir}/build/.vcpkg-bincache"
            },
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_MANIFEST_MODE": "ON"
            }
        },
        {
            "name": "msvc",
            "displayName": "Visual Studio 2022 (x64, /MD)",
            "inherits": "msvc-base",
            "binaryDir": "${sourceDir}/build/msvc",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/msvc-md.cmake"
            }
        },
        {
            "name": "msvc-vcpkg",
            "displayName": "Visual Studio 2022 (x64, /MD, vcpkg)",
            "inherits": "msvc-vcpkg-base",
            "binaryDir": "${sourceDir}/build/msvc-vcpkg",
            "cacheVariables": {
                "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/msvc-md.cmake"
            }
        },
        {
            "name": "msvc-static",
            "displayName": "Visual Studio 2022 (x64, /MT)",
            "inherits": "msvc-base",
            "binaryDir": "${sourceDir}/build/msvc-static",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/msvc-mt.cmake",
                "PROCROGUE_BUILD_GAME": "OFF",
                "PROCROGUE_BUILD_TESTS": "OFF",
                "PROCROGUE_BUILD_HEADLESS": "ON",
                "PROCROGUE_FETCH_SDL2": "OFF",
                "CMAKE_SUPPRESS_REGENERATION": "ON"
            }
        },
        {
            "name": "msvc-static-vcpkg",
            "displayName": "Visual Studio 2022 (x64, /MT, vcpkg)",
            "inherits": "msvc-vcpkg-base",
            "binaryDir": "${sourceDir}/build/msvc-static-vcpkg",
            "cacheVariables": {
                "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/msvc-mt.cmake"
            }
        },
        {
            "name": "ninja-release-tests",
            "displayName": "Ninja Release + tests",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/ninja-release-tests",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "PROCROGUE_BUILD_TESTS": "ON"
            },
            "description": "(with tests)"
        },
        {
            "name": "tests",
            "displayName": "Tests (no SDL)",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "binaryDir": "${sourceDir}/build/tests",
            "cacheVariables": {
                "PROCROGUE_BUILD_GAME": "OFF",
                "PROCROGUE_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "tests-smoke",
            "displayName": "Tests Smoke (no SDL)",
            "inherits": "tests"
        },
        {
            "name": "tests-headless-smoke",
            "displayName": "Tests Headless Smoke (no SDL)",
            "inherits": "tests"
        },
        {
            "name": "tests-settings",
            "displayName": "Tests Settings (no SDL)",
            "inherits": "tests"
        },
        {
            "name": "tests-commands",
            "displayName": "Tests Commands (no SDL)",
            "inherits": "tests"
        },
        {
            "name": "tests-replay",
            "displayName": "Tests Replay (no SDL)",
            "inherits": "tests"
        },
        {
            "name": "tests-replay-golden",
            "displayName": "Tests Replay Golden (no SDL)",
            "inherits": "tests"
        },
        {
            "name": "tests-economy",
            "displayName": "Tests Economy (no SDL)",
            "inherits": "tests"
        },
        {
            "name": "tests-saveio",
            "displayName": "Tests Save/Load IO (no SDL)",
            "inherits": "tests"
        }
    ],
    "buildPresets": [
        {
            "name": "build-msvc-base",
            "hidden": true,
            "jobs": 1,
            "nativeToolOptions": [
                "/nodeReuse:false"
            ]
        },
        {
            "name": "build-ninja-debug",
            "inherits": "build-msvc-base",
            "configurePreset": "ninja-debug",
            "configuration": "Debug",
            "targets": [
                "procrogue_headless"
            ]
        },
        {
            "name": "build-ninja-release",
            "inherits": "build-msvc-base",
            "configurePreset": "ninja-release",
            "configuration": "Release",
            "targets": [
                "procrogue_headless"
            ]
        },
        {
            "name": "build-ninja-debug-game",
            "inherits": "build-msvc-base",
            "configurePreset": "ninja-debug-game",
            "configuration": "Debug",
            "jobs": 1,
            "targets": [
                "proc_rogue"
            ]
        },
        {
            "name": "build-ninja-release-game",
            "inherits": "build-msvc-base",
            "configurePreset": "ninja-release-game",
            "configuration": "Release",
            "jobs": 1,
            "targets": [
                "proc_rogue"
            ]
        },
        {
            "name": "build-msvc-release",
            "inherits": "build-msvc-base",
            "configurePreset": "msvc",
            "configuration": "Release"
        },
        {
            "name": "build-msvc-vcpkg-release",
            "inherits": "build-msvc-base",
            "configurePreset": "msvc-vcpkg",
            "configuration": "Release"
        },
        {
            "name": "build-msvc-static-release",
            "inherits": "build-msvc-base",
            "configurePreset": "msvc-static",
            "configuration": "Release",
            "targets": [
                "procrogue_headless"
            ]
        },
        {
            "name": "build-msvc-static-vcpkg-release",
            "inherits": "build-msvc-base",
            "configurePreset": "msvc-static-vcpkg",
            "configuration": "Release"
        },
        {
            "name": "tests",
            "displayName": "Build tests (no SDL)",
            "inherits": "build-msvc-base",
            "configurePreset": "tests",
            "configuration": "Debug"
        },
        {
            "name": "tests-smoke",
            "displayName": "Build tests smoke (no SDL)",
            "inherits": "build-msvc-base",
            "configurePreset": "tests-smoke",
            "configuration": "Debug"
        },
        {
            "name": "tests-headless-smoke",
            "displayName": "Build tests headless smoke (no SDL)",
            "inherits": "build-msvc-base",
            "configurePreset": "tests-headless-smoke",
            "configuration": "Debug"
        },
        {
            "name": "tests-settings",
            "displayName": "Build tests settings (no SDL)",
            "inherits": "build-msvc-base",
            "configurePreset": "tests-settings",
            "configuration": "Debug"
        },
        {
            "name": "tests-commands",
            "displayName": "Build tests commands (no SDL)",
            "inherits": "build-msvc-base",
            "configurePreset": "tests-commands",
            "configuration": "Debug"
        },
        {
            "name": "tests-replay",
            "displayName": "Build tests replay (no SDL)",
            "inherits": "build-msvc-base",
            "configurePreset": "tests-replay",
            "configuration": "Debug"
        },
        {
            "name": "tests-replay-golden",
            "displayName": "Build tests replay golden (no SDL)",
            "inherits": "build-msvc-base",
            "configurePreset": "tests-replay-golden",
            "configuration": "Debug"
        },
        {
            "name": "tests-economy",
            "displayName": "Build tests economy (no SDL)",
            "inherits": "build-msvc-base",
            "configurePreset": "tests-economy",
            "configuration": "Debug"
        },
        {
            "name": "tests-saveio",
            "displayName": "Build tests save/load IO (no SDL)",
            "inherits": "build-msvc-base",
            "configurePreset": "tests-saveio",
            "configuration": "Debug"
        }
    ],
    "testPresets": [
        {
            "name": "tests",
            "displayName": "Run unit tests",
            "configurePreset": "tests",
            "configuration": "Debug",
            "execution": {
                "jobs": 8
            },
            "output": {
                "outputOnFailure": true,
                "shortProgress": true
            }
        },
        {
            "name": "tests-serial",
            "displayName": "Run unit tests (serial)",
            "inherits": "tests",
            "execution": {
                "jobs": 1
            }
        },
        {
            "name": "tests-smoke",
            "displayName": "Run smoke suite (17 core tests)",
            "inherits": "tests",
            "configurePreset": "tests-smoke",
            "execution": {
                "jobs": 4
            },
            "filter": {
                "include": {
                    "name": "^procrogue_(new_game_determinism|wfc_solver_basic|wfc_solver_unsat|physics_knockback_low_power_entity_block|action_info_view_turn|settings_minimap_zoom|action_palette|noise_localization|proc_spells|proc_monster_codename|crafting_procgen|trap_salvage_procgen|graffiti_procgen|sigil_procgen|shop_profiles|shrine_profiles|victory_plan)$"
                }
            }
        },
        {
            "name": "tests-headless-smoke",
            "displayName": "Run headless replay + perf smoke lane",
            "inherits": "tests",
            "configurePreset": "tests-headless-smoke",
            "execution": {
                "jobs": 1
            },
            "filter": {
                "include": {
                    "label": "headless_smoke"
                }
            }
        },
        {
            "name": "tests-settings",
            "displayName": "Run settings-focused tests",
            "inherits": "tests",
            "configurePreset": "tests-settings",
            "execution": {
                "jobs": 4
            },
            "filter": {
                "include": {
                    "label": "settings"
                }
            }
        },
        {
            "name": "tests-commands",
            "displayName": "Run command-focused tests",
            "inherits": "tests",
            "configurePreset": "tests-commands",
            "execution": {
                "jobs": 4
            },
            "filter": {
                "include": {
                    "label": "commands"
                }
            }
        },
        {
            "name": "tests-replay",
            "displayName": "Run replay-focused tests",
            "inherits": "tests",
            "configurePreset": "tests-replay",
            "execution": {
                "jobs": 1
            },
            "filter": {
                "include": {
                    "label": "replay"
                }
            }
        },
        {
            "name": "tests-replay-golden",
            "displayName": "Run replay golden regression tests",
            "inherits": "tests",
            "configurePreset": "tests-replay-golden",
            "execution": {
                "jobs": 1
            },
            "filter": {
                "include": {
                    "label": "replay_golden"
                }
            }
        },
        {
            "name": "tests-economy",
            "displayName": "Run economy-focused tests",
            "inherits": "tests",
            "configurePreset": "tests-economy",
            "execution": {
                "jobs": 4
            },
            "filter": {
                "include": {
                    "label": "economy"
                }
            }
        },
        {
            "name": "tests-saveio",
            "displayName": "Run save/load IO regression tests",
            "inherits": "tests",
            "configurePreset": "tests-saveio",
            "execution": {
                "jobs": 1
            },
            "filter": {
                "include": {
                    "label": "io"
                }
            }
        },
        {
            "name": "tests-saveio-fuzz",
            "displayName": "Run save/load fuzz safety tests",
            "inherits": "tests",
            "configurePreset": "tests-saveio",
            "execution": {
                "jobs": 1
            },
            "filter": {
                "include": {
                    "name": "^procrogue_save_load_fuzz_"
                }
            }
        },
        {
            "name": "tests-worldgen",
            "displayName": "Run worldgen-focused tests",
            "inherits": "tests",
            "filter": {
                "include": {
                    "label": "worldgen"
                }
            }
        },
        {
            "name": "tests-gameplay",
            "displayName": "Run gameplay-focused tests",
            "inherits": "tests",
            "filter": {
                "include": {
                    "label": "gameplay"
                }
            }
        }
    ]
}
